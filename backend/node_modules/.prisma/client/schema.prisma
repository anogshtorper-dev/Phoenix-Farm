generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  fullName     String
  role         String         @default("user")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  auditHistory AuditHistory[]

  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ponds     Pond[]

  @@map("departments")
}

model Species {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("species")
}

model Line {
  id        String   @id @default(cuid())
  name      String
  speciesId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lines")
}

model PondGroup {
  id            String   @id @default(cuid())
  name          String
  tempMin       Float?
  tempMax       Float?
  phMin         Float?
  phMax         Float?
  ecMin         Float?
  ecMax         Float?
  doMin         Float?
  doMax         Float?
  alkalinityMin Float?
  alkalinityMax Float?
  ammoniaMin    Float?
  ammoniaMax    Float?
  nitriteMin    Float?
  nitriteMax    Float?
  nitrateMin    Float?
  nitrateMax    Float?
  salinityMin   Float?
  salinityMax   Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ponds         Pond[]

  @@map("pond_groups")
}

model TreatmentPreset {
  id          String   @id @default(cuid())
  name        String
  description String?
  dosage      String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("treatment_presets")
}

model RASSystem {
  id                       String                    @id @default(cuid())
  systemName               String
  systemCode               String?
  systemVolume             Float?
  sortOrder                Int?
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  ponds                    Pond[]
  waterQualityMeasurements WaterQualityMeasurement[]
  alertRecords             AlertRecord[]
  systemsChecklists        AuditHistory[]

  @@map("ras_systems")
}

model Pond {
  id                       String                    @id @default(cuid())
  number                   String
  systemId                 String
  departmentId             String?
  groupId                  String?
  isActive                 Boolean                   @default(true)
  tankStatus               String?                   @default("Active")
  lastUpdated              DateTime?
  temperature              Float?
  ph                       Float?
  ec                       Float?
  do                       Float?
  alkalinity               Float?
  ammonia                  Float?
  nitrite                  Float?
  nitrate                  Float?
  salinity                 Float?
  turbidity                Float?
  fishCount                Int?
  species                  String?
  strainOrLine             String?
  femalesCount             Int?
  malesCount               Int?
  stockingDate             DateTime?
  density                  String?
  fishSize                 String?
  stage                    String?
  forSale                  String?
  gridRow                  Int?
  gridColumn               Int?
  notes                    String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  system                   RASSystem                 @relation(fields: [systemId], references: [id])
  department               Department?               @relation(fields: [departmentId], references: [id])
  group                    PondGroup?                @relation(fields: [groupId], references: [id])
  fishBatches              FishBatch[]
  healthSamples            HealthSample[]
  treatments               Treatment[]
  waterQualityMeasurements WaterQualityMeasurement[]

  @@map("ponds")
}

model FishBatch {
  id            String    @id @default(cuid())
  batchCode     String?
  currentTankId String?
  isActive      Boolean   @default(true)
  species       String?
  group         String?
  line          String?
  stockingDate  DateTime?
  fishCount     Int?
  avgWeight     Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  currentTank   Pond?     @relation(fields: [currentTankId], references: [id])

  @@map("fish_batches")
}

model HealthSample {
  id            String    @id @default(cuid())
  date          DateTime
  tankNumber    String?
  pondId        String?
  group         String?
  line          String?
  fishExamined  Int?
  finding1      String?
  finding2      String?
  finding3      String?
  finding4      String?
  finding5      String?
  diagnosis     String?
  images        String[]
  notes         String?
  treatment     String?
  treatmentDate DateTime?
  treatedBy     String?
  status        String    @default("Pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pond          Pond?     @relation(fields: [pondId], references: [id])

  @@map("health_samples")
}

model Treatment {
  id              String   @id @default(cuid())
  date            DateTime
  pondId          String?
  tankNumber      String?
  treatmentName   String?
  activeSubstance String?
  dosage          String?
  appliedBy       String?
  notes           String?
  status          String   @default("Pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pond            Pond?    @relation(fields: [pondId], references: [id])

  @@map("treatments")
}

model WaterQualityMeasurement {
  id          String     @id @default(cuid())
  date        DateTime
  systemId    String?
  pondId      String?
  temperature Float?
  ph          Float?
  ec          Float?
  do          Float?
  alkalinity  Float?
  ammonia     Float?
  nitrite     Float?
  nitrate     Float?
  salinity    Float?
  turbidity   Float?
  notes       String?
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  system      RASSystem? @relation(fields: [systemId], references: [id])
  pond        Pond?      @relation(fields: [pondId], references: [id])

  @@map("water_quality_measurements")
}

model AlertRecord {
  id         String     @id @default(cuid())
  systemId   String?
  pondId     String?
  metricType String
  value      Float
  threshold  Float?
  direction  String?
  isResolved Boolean    @default(false)
  resolvedAt DateTime?
  createdAt  DateTime   @default(now())
  system     RASSystem? @relation(fields: [systemId], references: [id])

  @@map("alert_records")
}

model MetricAcknowledgment {
  id             String   @id @default(cuid())
  pondId         String?
  metricType     String
  acknowledgedBy String?
  note           String?
  createdAt      DateTime @default(now())

  @@map("metric_acknowledgments")
}

model SpawningSystem {
  id                  String   @id @default(cuid())
  date                DateTime
  systemNumber        String
  spawn1Group         String?
  spawn1Line          String?
  spawn1NumberOfTanks Int?
  spawn2Group         String?
  spawn2Line          String?
  spawn2NumberOfTanks Int?
  spawn3Group         String?
  spawn3Line          String?
  spawn3NumberOfTanks Int?
  spawn4Group         String?
  spawn4Line          String?
  spawn4NumberOfTanks Int?
  notes               String?
  createdByName       String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("spawning_systems")
}

model AuditHistory {
  id          String     @id @default(cuid())
  entityType  String
  entityId    String?
  action      String
  description String?
  performedBy String?
  userId      String?
  before      Json?
  after       Json?
  systemId    String?
  createdAt   DateTime   @default(now())
  user        User?      @relation(fields: [userId], references: [id])
  system      RASSystem? @relation(fields: [systemId], references: [id])

  @@map("audit_history")
}
